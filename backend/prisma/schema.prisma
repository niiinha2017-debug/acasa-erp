  mdf_min_value     Float @default(0)
  mdf_avg_value     Float @default(0)
  mdf_max_value     Float @default(0)
  fita_value        Float @default(0)
  insumo_value      Float @default(0)
  rh_despesas_value Float @default(0)
  final_min_value   Float @default(0)
  final_avg_value   Float @default(0)
  final_max_value   Float @default(0)

  origem String @default("MATRIZ_OPERACIONAL") @db.VarChar(60)

