model agenda_fabrica_funcionarios {
  id                Int @id @default(autoincrement())
  agenda_fabrica_id Int
  funcionario_id    Int

  agenda_fabrica agenda_fabrica @relation(fields: [agenda_fabrica_id], references: [id], onDelete: Cascade)
  funcionario    funcionarios   @relation(fields: [funcionario_id], references: [id], onDelete: Cascade)

  @@index([agenda_fabrica_id])
  @@index([funcionario_id])
  @@map("agenda_fabrica_funcionarios")
}

model agenda_fabrica_apontamentos {
  id                Int @id @default(autoincrement())
  agenda_fabrica_id Int
  funcionario_id    Int
  inicio_em DateTime
  fim_em    DateTime
  criado_em DateTime @default(now())

  agenda_fabrica agenda_fabrica @relation(fields: [agenda_fabrica_id], references: [id], onDelete: Cascade)
  funcionario    funcionarios   @relation(fields: [funcionario_id], references: [id], onDelete: Cascade)

  @@index([agenda_fabrica_id])
  @@index([funcionario_id])
  @@map("agenda_fabrica_apontamentos")
}

// ---------- Apontamento de produção (horas reais para rateio de custo) ----------
// Time fica nesta tela; a agenda da produção apenas reflete (badge/link).
model apontamento_producao {
  id                Int       @id @default(autoincrement())
  agenda_fabrica_id Int?
  agenda_loja_id    Int?
  venda_id          Int?
  funcionario_id    Int
  categoria        String?   @db.VarChar(60)  // etapa: PRODUCAO_RECEBIDA, CORTE, MONTAGEM, etc.
  data              DateTime  @db.Date
  inicio_em         DateTime
  fim_em            DateTime
  pausa_inicio_em       DateTime?  // início da pausa atual (enquanto pausado)
  pausa_fim_em          DateTime?  // fim da última pausa (legado; múltiplas pausas usam pausa_total_segundos)
  pausa_total_segundos  Float?     // soma de todas as pausas já encerradas (permite pausar/retomar várias vezes)
  horas             Decimal?  @db.Decimal(6, 2) // opcional: horas decimais (ex: 2.5)
  custo_calculado   Decimal?  @db.Decimal(12, 2) // horas * funcionario.custo_hora
  observacao        String?   @db.VarChar(500)
  criado_em         DateTime  @default(now())
  atualizado_em     DateTime  @updatedAt

  agenda_fabrica agenda_fabrica? @relation(fields: [agenda_fabrica_id], references: [id], onDelete: SetNull)
  agenda_loja    agenda_loja?    @relation(fields: [agenda_loja_id], references: [id], onDelete: SetNull)
  venda          vendas?         @relation(fields: [venda_id], references: [id], onDelete: SetNull)
  funcionario    funcionarios   @relation(fields: [funcionario_id], references: [id], onDelete: Cascade)

  @@index([agenda_fabrica_id])
  @@index([agenda_loja_id])
  @@index([venda_id])
  @@index([funcionario_id])
  @@index([data])
  @@index([categoria])
  @@map("apontamento_producao")
}

model contas_pagar {
  id Int @id @default(autoincrement())

  // Fornecedor "centro" (ex: Cityfer)
  fornecedor_id Int
  fornecedor    Fornecedor @relation("contas_pagar_fornecedor", fields: [fornecedor_id], references: [id])

  // Fornecedor "cobrador" (ex: Rimad) - opcional
  fornecedor_cobrador_id Int?
  fornecedor_cobrador    Fornecedor? @relation("contas_pagar_fornecedor_cobrador", fields: [fornecedor_cobrador_id], references: [id])

  // Origem (opcional) para rastrear de onde veio (compra, etc.)
  origem_tipo String?
  origem_id   Int?

  mes_referencia Int
  ano_referencia Int

  descricao  String?
  observacao String?

  // valores
  valor_original   Decimal @default(0.00) @db.Decimal(12, 2)
  valor_compensado Decimal @default(0.00) @db.Decimal(12, 2)

  // status e forma de pagamento (vem das CONSTANTES)
  status                String
  forma_pagamento_chave String?

  // parcelamento (cartão/cheque em 6 meses)
  parcelas_total Int?
  parcela_numero Int?

  vencimento_em DateTime
  pago_em       DateTime?

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  despesa_id Int?      @unique
  despesa    despesas? @relation(fields: [despesa_id], references: [id])

  compensacoes fornecedor_compensacoes[] @relation("compensacoes_pagar")

  titulos titulos_financeiros[]

  @@index([fornecedor_id])
  @@index([fornecedor_cobrador_id])
  @@index([status])
  @@index([vencimento_em])
  @@index([origem_tipo])
  @@index([origem_id])
  @@map("contas_pagar")
}

model titulos_financeiros {
  id Int @id @default(autoincrement())

  // origem/vinculo (opcionais)
  despesa_id Int?
  despesa    despesas? @relation(fields: [despesa_id], references: [id], onDelete: SetNull)

  conta_pagar_id Int?
  conta_pagar    contas_pagar? @relation(fields: [conta_pagar_id], references: [id], onDelete: SetNull)

  conta_receber_id Int?
  conta_receber    contas_receber? @relation(fields: [conta_receber_id], references: [id], onDelete: SetNull)

  // tipo do titulo
  tipo String // CHEQUE | CARTAO | BOLETO | PARCELA_FORNECEDOR | etc.

  // dados principais
  valor         Decimal   @default(0.00) @db.Decimal(12, 2)
  status        String // EM_ABERTO | VENCIDO | PAGO | CANCELADO
  vencimento_em DateTime
  pago_em       DateTime?

  // parcelamento
  parcelas_total Int?
  parcela_numero Int?

  // metadados
  meta Json?

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([status])
  @@index([vencimento_em])
  @@index([despesa_id])
  @@index([conta_pagar_id])
  @@index([conta_receber_id])
  @@map("titulos_financeiros")
}

// ---------- Custos de Estrutura (Taxa de Máquina / Custo Hora Estrutura) ----------
// Um registro por mês/ano: ocupação, operacional, manutenção; custo_hora_estrutura = total / horas_uteis_mes
model custos_estrutura_mensal {
  id                          Int      @id @default(autoincrement())
  mes                         Int
  ano                         Int
  custo_ocupacao              Decimal  @default(0) @db.Decimal(12, 2)   // Aluguel, IPTU, Seguros
  custo_operacional           Decimal  @default(0) @db.Decimal(12, 2)   // Energia, Água, Internet
  custo_manutencao_depreciacao Decimal @default(0) @db.Decimal(12, 2) // Afiação, reparos, desgaste
  horas_uteis_mes             Decimal  @db.Decimal(8, 2)               // Capacidade instalada (horas)
  custo_hora_estrutura        Decimal  @default(0) @db.Decimal(10, 4)  // (soma custos) / horas_uteis_mes
  criado_em                   DateTime @default(now())
  atualizado_em               DateTime @updatedAt

  @@unique([mes, ano])
  @@index([mes, ano])
  @@map("custos_estrutura_mensal")
}

model contas_receber {
  id Int @id @default(autoincrement())

  // ✅ AGORA pode ser fornecedor OU cliente (um dos dois)
  fornecedor_id Int?
  fornecedor    Fornecedor? @relation("contas_receber_fornecedor", fields: [fornecedor_id], references: [id])

  cliente_id Int?
  cliente    Cliente? @relation("contas_receber_cliente", fields: [cliente_id], references: [id])

  // Origem (ex: VENDA)
  origem_tipo String?
  origem_id   Int?

  descricao  String?
  observacao String?

  valor_original   Decimal @default(0.00) @db.Decimal(12, 2)
  valor_compensado Decimal @default(0.00) @db.Decimal(12, 2)

  status                  String
  forma_recebimento_chave String?

  vencimento_em DateTime?
  recebido_em   DateTime?

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  compensacoes fornecedor_compensacoes[] @relation("compensacoes_receber")

  titulos titulos_financeiros[]

  @@index([fornecedor_id])
  @@index([cliente_id])
  @@index([status])
  @@index([vencimento_em])
  @@index([origem_tipo])
  @@index([origem_id])
  @@map("contas_receber")
}

model fornecedor_compensacoes {
  id Int @id @default(autoincrement())

  fornecedor_id Int
  fornecedor    Fornecedor @relation(fields: [fornecedor_id], references: [id])

  conta_pagar_id Int
  conta_pagar    contas_pagar @relation("compensacoes_pagar", fields: [conta_pagar_id], references: [id], onDelete: Cascade)

  conta_receber_id Int
  conta_receber    contas_receber @relation("compensacoes_receber", fields: [conta_receber_id], references: [id], onDelete: Cascade)

  valor            Decimal  @default(0.00) @db.Decimal(12, 2)
  data_compensacao DateTime @default(now())
  observacao       String?

  @@index([fornecedor_id])
  @@index([conta_pagar_id])
  @@index([conta_receber_id])
  @@map("fornecedor_compensacoes")
}

model compras {
  id Int @id @default(autoincrement())

  tipo_compra String

  venda_id Int?
  venda    vendas? @relation(fields: [venda_id], references: [id], onDelete: Cascade)

  fornecedor_id Int
  fornecedor    Fornecedor @relation(fields: [fornecedor_id], references: [id])

  venda_item_id Int?
  venda_item    vendas_itens? @relation(fields: [venda_item_id], references: [id], onDelete: SetNull)

  // ✅ agora é status financeiro (EM_ABERTO / VENCIDO / PAGO...)
  status String @default("EM_ABERTO")

  data_compra DateTime @default(now())

  // ✅ vencimento para virar VENCIDO automaticamente
  vencimento_em DateTime?

  valor_total Decimal @default(0.00) @db.Decimal(10, 2)

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  itens   compras_itens[]
  rateios compras_rateio[]

  @@index([tipo_compra])
  @@index([venda_id])
  @@index([fornecedor_id])
  @@index([status])
  @@index([vencimento_em])
  @@map("compras")
}

model compras_itens {
  id        Int     @id @default(autoincrement())
  compra_id Int
  compra    compras @relation(fields: [compra_id], references: [id], onDelete: Cascade)

  produto_id Int?
  produto    produtos? @relation(fields: [produto_id], references: [id], onDelete: SetNull)

  // ✅ CAMPOS REPLICADOS PARA HISTÓRICO E RELATÓRIO DETALHADO
  nome_produto String
  marca        String?
  cor          String?
  medida       String?
  categoria_base String?
  unidade      String

  quantidade     Decimal @default(1.00) @db.Decimal(10, 2)
  valor_unitario Decimal @default(0.00) @db.Decimal(10, 2)
  valor_total    Decimal @default(0.00) @db.Decimal(10, 2)

  criado_em DateTime @default(now())

  @@index([compra_id])
  @@index([produto_id])
  @@map("compras_itens")
}

model compras_rateio {
  id Int @id @default(autoincrement())

  compra_id Int
  compra    compras @relation(fields: [compra_id], references: [id], onDelete: Cascade)

  // ambiente por snapshot (texto igual ao vendas_itens.nome_ambiente)
  nome_ambiente String

  // quanto desse total foi alocado nesse ambiente
  valor_alocado Decimal @default(0.00) @db.Decimal(10, 2)

  criado_em DateTime @default(now())

  @@unique([compra_id, nome_ambiente]) // ✅ impede duplicar o mesmo ambiente na mesma compra
  @@index([compra_id])
  @@index([nome_ambiente])
  @@map("compras_rateio")
}

model Empresa {
  id            Int      @id @default(1) // Forçamos o ID 1
  razao_social  String?
  nome_fantasia String?
  cnpj          String?  @unique
  ie            String?
  inscricao_municipal String?
  regime_tributario   String?
  instagram_url       String?
  whatsapp_url        String?
  whatsapp_api_token  String?   // (legado) Token Meta – uso descontinuado; use Evolution API
  evolution_api_url   String?   // URL da Evolution API (ex: http://localhost:8080)
  evolution_api_key   String?   // API Key da Evolution API
  evolution_instance_name String? // Nome da instância WhatsApp (ex: acasa-erp)
  site                String?
  cor_marca           String?  @db.VarChar(7)
  logradouro    String?
  numero        String?
  bairro        String?
  cidade        String?
  uf            String?  @db.VarChar(2)
  cep           String?
  email         String?
  telefone      String?
  banco_titular String?
  banco_nome    String?
  banco_agencia String?
  banco_conta   String?
  pix           String?
  // Representante legal (contratos e documentos)
  representante_legal_nome     String?
  representante_legal_cpf     String?
  representante_legal_rg      String?
  representante_legal_socio_nome String?
  representante_legal_socio_cpf  String?
  representante_legal_socio_rg   String?
  // Quando o vendedor não preenche "Representante da venda": true = usar Sócio no contrato; false = usar Representante Legal
  contrato_usar_socio_quando_vazio Boolean? @default(true)
  representante_estado_civil  String?
  // % de perda padrão para cálculo de desperdício (Material Comprado - Usado - Retalhos = Perda Real)
  perda_padrao_percentual     Decimal? @db.Decimal(5, 2)
  // Valor da hora do comercial (R$/h) para custo do tempo de negociação na DRE Detalhada
  valor_hora_comercial        Decimal? @db.Decimal(10, 2)
  // Horas úteis da fábrica no mês (base de cálculo para Taxa de Máquina / Custos de Estrutura e timeline). Ex.: 220 se os funcionários trabalham 220h/mês.
  horas_uteis_mes_fabrica     Decimal? @db.Decimal(8, 2)
  updated_at    DateTime @updatedAt

  @@map("empresa") // Nome da tabela no banco de dados
}

model clausulas_modelos {
  id Int @id @default(autoincrement())

  // ORCAMENTO | CONTRATO (controlado pela aplicação)
  tipo       String
  modulo_key String   // ex: OBJETO, PRECO_PAGAMENTO, PRAZO_ENTREGA...
  titulo     String
  texto      String   @db.Text  // cláusulas longas
  ordem      Int      @default(0)

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@unique([tipo, modulo_key])
  @@index([tipo, ordem])
  @@map("clausulas_modelos")
}

enum SearchStrategy {
  MIN_PRICE
  AVG_PRICE
  MAX_PRICE
}

model GlobalConfig {
  id              Int            @id @default(autoincrement())
  key             String         @unique @db.VarChar(80)
  search_strategy SearchStrategy @default(AVG_PRICE)
  criado_em       DateTime       @default(now())
  atualizado_em   DateTime       @updatedAt

  @@map("global_config")
}

model OperationalMatrix {
