generator client {
  provider      = "prisma-client-js"
  binaryTargets  = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
 }

model usuarios {
  id            Int      @id @default(autoincrement())
  nome          String
  usuario       String   @unique
  email         String   @unique
  senha         String
  status        String
  is_admin      Boolean  @default(false)
  cargo         String?  // VENDEDOR_LOJA | MONTADOR_FABRICA (Loja vs. Fábrica)
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  funcionario_id Int?      @unique  // FK para funcionarios
  funcionario    funcionarios? @relation(fields: [funcionario_id], references: [id], onDelete: SetNull)

  recuperacoes recuperacao_senha[] // ✅ lado oposto da relação
  permissoes   usuarios_permissoes[]
  vendas_representante vendas[] @relation("vendas_representante_usuario")
  comissoes_responsavel vendas_comissoes[] @relation("vendas_comissao_responsavel_usuario")
  agenda_loja_alterados agenda_loja[] @relation("AgendaLojaAlteradoPor")
  agenda_fabrica_alterados agenda_fabrica[] @relation("AgendaFabricaAlteradoPor")
  agenda_loja_criados agenda_loja[] @relation("AgendaLojaCriadoPor")
  agenda_fabrica_criados agenda_fabrica[] @relation("AgendaFabricaCriadoPor")

  @@map("usuarios")
 }

model recuperacao_senha {
  id           Int      @id @default(autoincrement())
  usuario_id   Int
  email        String
  senha_antiga String?
  senha_nova   String?
  token        String?
  utilizado    Boolean  @default(false)
  criado_em    DateTime @default(now())

  usuario usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id])
  @@map("recuperacao_senha")
 }

model usuarios_permissoes {
  id Int @id @default(autoincrement())

  usuario_id   Int
  permissao_id Int

  usuario   usuarios   @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  permissao permissoes @relation(fields: [permissao_id], references: [id], onDelete: Cascade)

  @@unique([usuario_id, permissao_id])
  @@index([usuario_id])
  @@index([permissao_id])
  @@map("usuarios_permissoes")
 }

model permissoes {
  id        Int      @id @default(autoincrement())
  chave     String   @unique
  descricao String?
  criado_em DateTime @default(now())

  usuarios usuarios_permissoes[]

  @@map("permissoes")
}

model auditoria_permissoes {
  id                      Int      @id @default(autoincrement())
  usuario_id_alterado      Int      // usuário cujas permissões foram alteradas
  alterado_por_usuario_id  Int      // quem fez a alteração
  alterado_em              DateTime @default(now())

  @@index([usuario_id_alterado])
  @@map("auditoria_permissoes")
}

model Cliente {
  id Int @id @default(autoincrement())

  indicacao_id Int?
  indicacao_origem String?
  indicacao    Cliente?  @relation("ClienteIndicacao", fields: [indicacao_id], references: [id])
  indicados    Cliente[] @relation("ClienteIndicacao")

  nome_completo   String
  razao_social    String?
  nome_fantasia   String?
  data_nascimento DateTime?

  cpf  String?
  rg   String?
  cnpj String?
  ie   String?

  estado_civil String? // SOLTEIRO | CASADO
  nome_conjuge String?

  telefone String?
  whatsapp String?
  email    String?

  enviar_aniversario_email    Boolean @default(true)
  enviar_aniversario_whatsapp Boolean @default(false)

  cep         String?
  endereco    String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?

  status   String  @default("ATIVO") // Pipeline do cliente (CADASTRO, MEDICAO_VENDA, etc.) - definido pelo fluxo
  situacao String? // Ativo / Inativo / Pendente (exibido no cadastro)

  // Vendedor responsável (funcionário da loja) e profissão para contrato
  vendedor_responsavel_id Int?
  vendedor_responsavel    funcionarios? @relation("ClienteVendedorResponsavel", fields: [vendedor_responsavel_id], references: [id], onDelete: SetNull)
  profissao               String?

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  contas_receber contas_receber[] @relation("contas_receber_cliente")

  orcamentos   orcamentos[]
  vendas       vendas[]
  contratos   contratos[]
  agendamentos_loja    agenda_loja[]
  agendamentos_fabrica agenda_fabrica[]
  projetos     projetos[]
  medicoes_orcamento   medicao_orcamento[]
  pre_medicoes         pre_medicao[]

  @@unique([cpf])
  @@unique([cnpj])
  @@unique([email])
  @@index([indicacao_id])
  @@index([vendedor_responsavel_id])
  @@map("clientes")
 }

model orcamentos {
  id Int @id @default(autoincrement())

  cliente_id Int
  cliente    Cliente @relation(fields: [cliente_id], references: [id])

  // Vendedor responsável pelo cliente no momento do orçamento (espelho do cliente para todo o processo)
  vendedor_responsavel_id Int?
  vendedor_responsavel    funcionarios? @relation("OrcamentoVendedor", fields: [vendedor_responsavel_id], references: [id], onDelete: SetNull)

  cliente_nome_snapshot String
  cliente_cpf_snapshot  String
  qtd_ambientes         Int    @default(0)

  // Cláusulas específicas deste orçamento (pré-contrato / termos)
  // Armazena um array JSON de objetos { modulo_key, titulo, texto }
  clausulas Json?

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  itens       orcamento_itens[]
  agendamentos_loja agenda_loja[]
  agendamento_fabrica agenda_fabrica?
  medicoes_orcamento medicao_orcamento[]

  // ✅ agora é 0..1 venda por orçamento
  venda    vendas?
  projetos projetos[]

  @@index([cliente_id])
  @@index([vendedor_responsavel_id])
  @@map("orcamentos")
}

model orcamento_itens {
  id           Int        @id @default(autoincrement())
  orcamento_id Int
  orcamento    orcamentos @relation(fields: [orcamento_id], references: [id], onDelete: Cascade)

  nome_ambiente  String
  descricao      String
  valor_unitario Decimal @db.Decimal(10, 2)
  valor_total    Decimal @db.Decimal(10, 2)
  observacao     String  @db.VarChar(2000)

  criado_em DateTime @default(now())

  @@index([orcamento_id])
  @@map("orcamento_itens")
 }

model vendas {
  id Int @id @default(autoincrement())

  cliente_id Int
  cliente    Cliente @relation(fields: [cliente_id], references: [id])

  orcamento_id Int        @unique
  orcamento    orcamentos @relation(fields: [orcamento_id], references: [id], onDelete: Restrict)

  // Vendedor responsável pelo cliente no momento da venda (espelho para todo o processo)
  vendedor_responsavel_id Int?
  vendedor_responsavel    funcionarios? @relation("VendaVendedor", fields: [vendedor_responsavel_id], references: [id], onDelete: SetNull)

  status String

  data_venda DateTime @default(now())
  endereco_entrega String?

  // ✅ NOVO: base real do pós-venda (não é o orçado)
  valor_vendido Decimal @default(0.00) @db.Decimal(10, 2)

  // Valor do contrato (sem juros) – quando diferente de valor_vendido, o contrato mostra este valor; contas a receber usam valor_vendido/soma das parcelas
  valor_base_contrato Decimal? @db.Decimal(10, 2)

  // (mantém seus campos calculados)
  valor_bruto Decimal @default(0.00) @db.Decimal(10, 2)

  // Juros e taxas de cartão: salvos na venda (não em Despesas)
  taxa_pagamento_percentual_aplicado Decimal? @db.Decimal(5, 2)
  valor_taxa_pagamento               Decimal  @default(0.00) @db.Decimal(10, 2)

  taxa_nota_fiscal_percentual_aplicado Decimal? @db.Decimal(5, 2)
  valor_nota_fiscal                    Decimal  @default(0.00) @db.Decimal(10, 2)

  valor_total Decimal @default(0.00) @db.Decimal(10, 2)

  // Representante da venda (contrato) – opcional; se preenchido, usado no PDF em vez do cadastro da empresa
  representante_venda_nome String?
  representante_venda_cpf  String?
  representante_venda_rg   String?
  representante_venda_usuario_id Int?
  representante_venda_funcionario_id Int?
  // Segundo representante (sequência pode ser alterada no frontend)
  representante_venda_2_nome String?
  representante_venda_2_cpf  String?
  representante_venda_2_rg   String?

  // Pagamento combinado para o ato da medição: exibir alerta "RECEBER NO ATO" no painel de obras
  receber_no_ato_medicao Boolean @default(false)

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  itens        vendas_itens[]
  comissoes    vendas_comissoes[]
  pagamentos   vendas_pagamentos[] // ✅ NOVO
  formas_pagamento vendas_formas_pagamento[] // formas agrupadas (valor base, com/sem juros) para contrato
  agendamentos_loja    agenda_loja[]
  agendamentos_fabrica agenda_fabrica[]
  apontamentos_producao apontamento_producao[]
  representante_venda_usuario usuarios? @relation("vendas_representante_usuario", fields: [representante_venda_usuario_id], references: [id], onDelete: SetNull)
  representante_venda_funcionario funcionarios? @relation("vendas_representante_funcionario", fields: [representante_venda_funcionario_id], references: [id], onDelete: SetNull)
  // Adicione projetos[] aqui
  projetos     projetos[]

  compras   compras[]
  contratos contratos[]

  @@index([cliente_id])
  @@index([status])
  @@index([vendedor_responsavel_id])
  @@index([representante_venda_usuario_id])
  @@index([representante_venda_funcionario_id])
  @@map("vendas")
 }

model contratos {
  id Int @id @default(autoincrement())

  cliente_id Int
  cliente    Cliente @relation(fields: [cliente_id], references: [id], onDelete: Restrict)

  venda_id Int?
  venda    vendas? @relation(fields: [venda_id], references: [id], onDelete: SetNull)

  // Vendedor responsável pelo cliente no momento do contrato (espelho para todo o processo)
  vendedor_responsavel_id Int?
  vendedor_responsavel    funcionarios? @relation("ContratoVendedor", fields: [vendedor_responsavel_id], references: [id], onDelete: SetNull)

  numero     String   // ex: CONT-2025-001
  descricao  String?
  status     String   // RASCUNHO | VIGENTE | ENCERRADO | CANCELADO
  valor      Decimal  @default(0.00) @db.Decimal(10, 2)
  data_inicio DateTime?
  data_fim   DateTime?
  data_assinatura DateTime?  // quando o contrato foi assinado (ex.: assinatura online)
  zapsign_doc_token String?  // token do documento na ZapSign (assinatura por e-mail)
  assinatura_presencial Boolean @default(false) // true = assinatura na loja (PDF sócio); false = eletrônica (PDF representante legal/CNPJ)

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  assinaturas_log       assinaturas_log[]
  link_publico_tokens   contratos_link_publico[]

  @@index([cliente_id])
  @@index([venda_id])
  @@index([vendedor_responsavel_id])
  @@index([status])
  @@map("contratos")
 }

model contratos_link_publico {
  id           Int      @id @default(autoincrement())
  short_token  String   @unique  // token curto para URL (ex: 8 caracteres)
  contrato_id  Int
  expira_em    DateTime
  criado_em    DateTime @default(now())
  contrato     contratos @relation(fields: [contrato_id], references: [id], onDelete: Cascade)
  @@index([short_token])
  @@index([expira_em])
  @@map("contratos_link_publico")
 }

model assinaturas_log {
  id Int @id @default(autoincrement())

  contrato_id Int
  contrato    contratos @relation(fields: [contrato_id], references: [id], onDelete: Cascade)

  data_hora         DateTime   @default(now())
  ip_address        String?
  dispositivo       String?    // User-Agent
  hash_documento    String?    // SHA-256 do PDF no momento da assinatura
  metodo_verificacao String?   // ex: "Aceite via Link WhatsApp/SMS"

  @@index([contrato_id])
  @@map("assinaturas_log")
 }

model vendas_pagamentos {
  id Int @id @default(autoincrement())

  venda_id Int
  venda    vendas @relation(fields: [venda_id], references: [id], onDelete: Cascade)

  forma_pagamento_chave String // DINHEIRO | PIX | DEBITO | CREDITO | BOLETO | CHEQUE | TRANSFERENCIA
  valor                 Decimal @default(0.00) @db.Decimal(10, 2)

  // ✅ datas para controle real
  data_prevista_recebimento DateTime? // ex: data que você vai receber (ou data entrega)
  data_recebimento          DateTime? // quando entrou de fato

  status_financeiro_chave String @default("EM_ABERTO") // STATUS_FINANCEIRO

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([venda_id])
  @@index([forma_pagamento_chave])
  @@index([status_financeiro_chave])
  @@map("vendas_pagamentos")
 }

// Formas de pagamento da venda: juros e taxas de cartão ficam aqui e em vendas.valor_taxa_pagamento
model vendas_formas_pagamento {
  id Int @id @default(autoincrement())

  venda_id Int
  venda    vendas @relation(fields: [venda_id], references: [id], onDelete: Cascade)

  forma_pagamento_chave String // CREDITO | PIX | ...
  valor_base             Decimal @db.Decimal(10, 2)   // valor sem juros desta parte (para contrato)
  quantidade_parcelas    Int     @default(1)         // 1 = à vista
  com_juros              Boolean @default(false)     // true = cartão parcelado com juros; valor real a receber > valor_base

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([venda_id])
  @@map("vendas_formas_pagamento")
 }

model vendas_itens {
  id       Int    @id @default(autoincrement())
  venda_id Int
  venda    vendas @relation(fields: [venda_id], references: [id], onDelete: Cascade)

  nome_ambiente String
  descricao     String
  observacao    String

  quantidade     Decimal @default(1.00) @db.Decimal(10, 2)
  valor_unitario Decimal @db.Decimal(10, 2)
  valor_total    Decimal @db.Decimal(10, 2)

  compras compras[]

  criado_em DateTime @default(now())

  @@index([venda_id])
  @@map("vendas_itens")
 }

model vendas_comissoes {
  id Int @id @default(autoincrement())

  venda_id Int
  venda    vendas @relation(fields: [venda_id], references: [id], onDelete: Cascade)

  // chave da constante: VENDEDOR / ARQUITETO / PROJETISTA
  tipo_comissao_chave String

  // snapshot aplicado no dia (ex: 3 / 5 / 10)
  percentual_aplicado Decimal @db.Decimal(5, 2)

  // valor calculado
  valor_comissao Decimal @default(0.00) @db.Decimal(10, 2)

  // opcional: quem é (nome, ou depois vira vínculo com usuario/funcionario)
  responsavel_nome String?
  responsavel_usuario_id Int?
  responsavel_funcionario_id Int?

  responsavel_usuario usuarios? @relation("vendas_comissao_responsavel_usuario", fields: [responsavel_usuario_id], references: [id], onDelete: SetNull)
  responsavel_funcionario funcionarios? @relation("vendas_comissao_responsavel_funcionario", fields: [responsavel_funcionario_id], references: [id], onDelete: SetNull)

  criado_em DateTime @default(now())

  @@index([venda_id])
  @@index([tipo_comissao_chave])
  @@index([responsavel_usuario_id])
  @@index([responsavel_funcionario_id])
  @@map("vendas_comissoes")
 }

model Fornecedor {
  id              Int      @id @default(autoincrement())
  razao_social    String
  nome_fantasia   String
  cnpj            String   @unique
  ie              String?
  telefone        String?
  whatsapp        String?
  email           String?
  cep             String?
  endereco        String?
  numero          String?
  complemento     String?
  bairro          String?
  cidade          String?
  estado          String?
  forma_pagamento   String?
  data_vencimento   Int?
  ramo_atividade    String?
  prazo_entrega_dias Int?
  saldo_credito     Decimal? @db.Decimal(10, 2)
  criado_em         DateTime @default(now())
  atualizado_em   DateTime @updatedAt

  produtos         produtos[] // 👈 LADO OPOSTO DA RELAÇÃO
  plano_corte      plano_corte[]
  plano_corte_item plano_corte_item[]

  // ===== Financeiro (Fornecedor) =====
  contas_pagar          contas_pagar[]   @relation("contas_pagar_fornecedor")
  contas_pagar_cobrador contas_pagar[]   @relation("contas_pagar_fornecedor_cobrador")
  contas_receber        contas_receber[] @relation("contas_receber_fornecedor")

  compensacoes_fornecedor fornecedor_compensacoes[]
  compras                 compras[]
  agendamentos_loja       agenda_loja[]
  agendamentos_fabrica    agenda_fabrica[]

  @@map("fornecedor")
 }

model produtos {
  id            Int        @id @default(autoincrement())
  fornecedor_id Int
  fornecedor    Fornecedor @relation(fields: [fornecedor_id], references: [id])

  nome_produto String
  marca        String?
  cor          String?
  medida       String?
  unidade      String?

  largura_mm    Int?
  comprimento_mm Int?
  espessura_mm  Int?
  metragem_rolo_m Decimal? @db.Decimal(10, 3)
  preco_m2      Decimal? @db.Decimal(10, 2)
  adicional_fita_m2 Decimal? @db.Decimal(10, 2)

  quantidade      Int?     @default(0)
  estoque_minimo  Int?     @default(0)
  valor_unitario  Decimal? @db.Decimal(10, 2)
  custo_unitario_real Decimal? @db.Decimal(10, 4)
  valor_total     Decimal? @db.Decimal(10, 2)

  unidade_compra   String?
  unidade_consumo  String?
  fator_conversao  Float?

  // Conversão para custo unitário de consumo na Estratégia de Preço (Aba Insumos)
  insumo_fator_conversao   Decimal? @db.Decimal(10, 3)
  insumo_unidade_referencia String?
  insumo_consumo_m2        Decimal? @db.Decimal(10, 4)

  categoria_base String @default("PRIMARIA")
  fita_vinculada_id Int?

  // Sub-categoria para produtos do tipo FERRAGEM
  // Ex: DOBRADICA, CORREDICA, PUXADOR, FECHADURA, SUPORTE, AMORTECEDOR, OUTRO
  categoria_ferragem String?

  // ✅ novo campo (1 imagem)
  imagem_url String?

  status String @default("ATIVO")

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  plano_corte_consumo plano_corte_consumo[]
  compras_itens       compras_itens[]
  chapas_inteiras     estoque_chapa_inteira[]
  retalhos            estoque_retalho[]

  @@index([fornecedor_id])
  @@index([fita_vinculada_id])
  @@map("produtos")
 }

model plano_corte {
  id            Int      @id @default(autoincrement())
  fornecedor_id Int
  data_venda    DateTime

  valor_total Decimal @db.Decimal(10, 2)
  status      String

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  fornecedor Fornecedor @relation(fields: [fornecedor_id], references: [id])

  produtos     plano_corte_produto[]
  consumos     plano_corte_consumo[]
  agendamentos agenda_fabrica[]

  @@map("plano_corte")
 }

model plano_corte_item {
  id            Int @id @default(autoincrement())
  fornecedor_id Int

  nome_produto String
  marca        String? // ✅ NOVO
  cor          String?
  medida       String?
  unidade      String?

  largura_mm     Int?
  comprimento_mm Int?
  espessura_mm   Int?
  preco_m2       Decimal? @db.Decimal(10, 2)

  quantidade     Int
  valor_unitario Decimal @db.Decimal(10, 2)
  valor_total    Decimal @db.Decimal(10, 2)

  status String

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  ultimo_valor_vendido  Decimal   @default(0.00) @db.Decimal(10, 2)
  ultimo_vendido_em     DateTime?
  ultimo_valor_comprado Decimal   @default(0.00) @db.Decimal(10, 2)
  ultimo_comprado_em    DateTime?

  fornecedor Fornecedor @relation(fields: [fornecedor_id], references: [id])

  produtos plano_corte_produto[]

  @@index([fornecedor_id])
  @@map("plano_corte_item")
 }

model plano_corte_produto {
  id             Int @id @default(autoincrement())
  plano_corte_id Int
  item_id        Int

  quantidade     Decimal @db.Decimal(10, 2)
  valor_unitario Decimal @db.Decimal(10, 2)
  valor_total    Decimal @db.Decimal(10, 2)
  status         String

  largura_mm    Int?
  comprimento_mm Int?
  espessura_mm  Int?
  preco_m2      Decimal? @db.Decimal(10, 2)

  plano_corte plano_corte      @relation(fields: [plano_corte_id], references: [id])
  item        plano_corte_item @relation(fields: [item_id], references: [id])

  @@index([plano_corte_id])
  @@index([item_id])
  @@map("plano_corte_produto")
 }

model plano_corte_consumo {
  id             Int @id @default(autoincrement())
  plano_corte_id Int
  produto_id     Int

  quantidade Decimal @db.Decimal(10, 2)

  criado_em DateTime @default(now())

  plano_corte plano_corte @relation(fields: [plano_corte_id], references: [id])
  produto     produtos    @relation(fields: [produto_id], references: [id])

  @@unique([plano_corte_id, produto_id]) // ✅ não duplica consumo no mesmo plano
  @@map("plano_corte_consumo")
 }

model funcionarios {
  id Int @id @default(autoincrement())

  usuario_id Int?      @unique  // FK para usuarios
  usuario    usuarios? @relation

  // ======================
  // DADOS PESSOAIS
  // ======================
  nome            String
  cpf             String    @unique
  pis             String?   @db.VarChar(20)
  rg              String?
  data_nascimento DateTime?
  telefone        String?
  whatsapp        String?
  email           String?
  estado_civil    String?
  escolaridade    String?

  // ======================
  // DADOS DA EMPRESA
  // ======================
  unidade String? // FÁBRICA | LOJA
  setor   String?
  cargo   String?
  funcao  String?

  // ======================
  // ENDEREÇO
  // ======================
  cep         String?
  endereco    String?
  numero      String?
  complemento String? // <--- ADICIONADO AQUI
  bairro      String?
  cidade      String?
  estado      String?

  // ======================
  // REGISTRO / VÍNCULO (Essencial para cálculo de Férias)
  // ======================
  data_inicio DateTime?
  admissao DateTime?
  demissao DateTime?

  // ======================
  // FINANCEIRO
  // ======================
  salario_base                Decimal? @db.Decimal(12, 2)
  impostos_encargos_percentual Decimal? @db.Decimal(5, 2)  // % sobre salário (INSS, FGTS, etc.)
  custo_total_mensal          Decimal? @db.Decimal(12, 2)  // calculado: base*(1+impostos/100)+adicional+vales
  salario_adicional           Decimal? @db.Decimal(12, 2)
  custo_hora                  Decimal? @db.Decimal(12, 2)

  tem_vale Boolean  @default(false)
  vale     Decimal? @db.Decimal(12, 2)

  tem_vale_transporte Boolean  @default(false)
  vale_transporte     Decimal? @db.Decimal(12, 2)

  // ======================
  // HORÁRIOS (Armazenados como String: "08:00")
  // ======================
  horario_entrada_1 String?
  horario_saida_1   String?
  horario_entrada_2 String?
  horario_saida_2   String?

  // SABADO
  horario_sabado_entrada_1 String?
  horario_sabado_saida_1   String?

  // ======================
  // CARGA HORÁRIA
  // ======================
  carga_horaria_dia    Decimal? @db.Decimal(5, 2)
  carga_horaria_semana Decimal? @db.Decimal(5, 2)

  // ======================
  // PAGAMENTO
  // ======================
  forma_pagamento String?
  dia_pagamento   Int?
  banco           String?
  agencia         String?
  conta           String?
  pix_tipo_chave  String?
  pix_chave       String?
  status          String  @default("ATIVO") @db.VarChar(20)

  // ======================
  // PRODUÇÃO / DESPESAS
  // ======================
  despesas despesas[]
  vendas_representante vendas[] @relation("vendas_representante_funcionario")
  comissoes_responsavel vendas_comissoes[] @relation("vendas_comissao_responsavel_funcionario")

  // ======================
  // CONTROLE
  // ======================
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  ponto_dispositivos   ponto_dispositivos[]
  ponto_registros      ponto_registros[]
  ponto_convites       ponto_convites[]
  ponto_justificativas ponto_justificativas[]
  equipe_loja          agenda_loja_funcionarios[]
  apontamentos_loja    agenda_loja_apontamentos[]
  equipe_fabrica       agenda_fabrica_funcionarios[]
  apontamentos_fabrica agenda_fabrica_apontamentos[]
  apontamentos_producao apontamento_producao[]
  custo_constante funcionario_custo_constante?
  clientes_vendedor    Cliente[] @relation("ClienteVendedorResponsavel")
  orcamentos_vendedor  orcamentos[] @relation("OrcamentoVendedor")
  vendas_vendedor      vendas[] @relation("VendaVendedor")
  contratos_vendedor   contratos[] @relation("ContratoVendedor")

  @@map("funcionarios")
 }

model funcionario_custo_constante {
  id Int @id @default(autoincrement())

  funcionario_id Int @unique
  funcionario funcionarios @relation(fields: [funcionario_id], references: [id], onDelete: Cascade)

  salario_base                Decimal @default(0) @db.Decimal(12, 2)
  impostos_encargos_percentual Decimal @default(0) @db.Decimal(5, 2)
  salario_adicional           Decimal @default(0) @db.Decimal(12, 2)
  beneficios                  Decimal @default(0) @db.Decimal(12, 2)
  horas_mes_base              Decimal @default(176) @db.Decimal(8, 2)
  custo_total_mensal          Decimal @default(0) @db.Decimal(12, 2)
  custo_hora                  Decimal @default(0) @db.Decimal(12, 4)

  criado_em DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([funcionario_id])
