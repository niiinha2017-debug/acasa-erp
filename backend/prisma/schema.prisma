model projetos {
  id         Int     @id @default(autoincrement())
  codigo     String  @unique @db.VarChar(60)
  cliente_id Int
  cliente    Cliente @relation(fields: [cliente_id], references: [id]) // Adicione esta linha

  // Vínculos com a origem
  orcamento_id Int?        @unique
  orcamento    orcamentos? @relation(fields: [orcamento_id], references: [id])

  venda_id Int?    @unique
  venda    vendas? @relation(fields: [venda_id], references: [id])

  status_atual String @default("CLIENTE_CADASTRADO")

  agendamentos_loja    agenda_loja[]
  agendamentos_fabrica agenda_fabrica[]
  medicoes_fina        medicao_fina[]

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([cliente_id])
  @@index([status_atual])
  @@map("projetos")
}

// Medição Fina: dados reais do ambiente antes da produção (por projeto + ambiente)
model medicao_fina {
  id         Int      @id @default(autoincrement())
  projeto_id Int
  projeto    projetos @relation(fields: [projeto_id], references: [id], onDelete: Cascade)

  nome_ambiente String @db.VarChar(120)

  // Variáveis críticas (cm)
  altura_cm    Decimal? @db.Decimal(10, 2)
  largura_cm   Decimal? @db.Decimal(10, 2)
  profundidade_cm Decimal? @db.Decimal(10, 2)
  // Medidas do projeto Promob (para conferência vs medida real)
  altura_promob_cm    Decimal? @db.Decimal(10, 2)
  largura_promob_cm   Decimal? @db.Decimal(10, 2)
  profundidade_promob_cm Decimal? @db.Decimal(10, 2)
  prumo_ok     Boolean?  // estado da parede: prumo
  esquadro_ok  Boolean?  // estado da parede: esquadro

  // Checklist interferências (JSON array de chaves: AGUA, GAS, ESGOTO, TOMADAS, AR_CONDICIONADO, RODAPES, GESSO)
  interferencias Json?

  // Checklist de conferência (obra pronta para medição)
  conferencia_eletrica_ok   Boolean?
  conferencia_hidraulica_ok Boolean?
  conferencia_gas_ok        Boolean?
  conferencia_alvenaria_ok  Boolean?

  observacoes_montador String? @db.Text

  // Planta baixa interativa: JSON com paredes, pontos técnicos e textos (coordenadas e medidas para orçamento)
  planta_baixa_json Json?

  concluida Boolean @default(false)
  criado_em DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@unique([projeto_id, nome_ambiente])
  @@index([projeto_id])
  @@map("medicao_fina")
}

// Medição para Orçamento: visita no cliente, medidas gerais + observações (alimenta criação de orçamento)
model medicao_orcamento {
  id            Int       @id @default(autoincrement())
  agenda_loja_id Int      @unique
  agenda_loja   agenda_loja @relation(fields: [agenda_loja_id], references: [id], onDelete: Cascade)
  cliente_id    Int?
  cliente       Cliente?  @relation(fields: [cliente_id], references: [id], onDelete: SetNull)
  orcamento_id  Int?
  orcamento     orcamentos? @relation(fields: [orcamento_id], references: [id], onDelete: SetNull)
  medidas_gerais String?  @db.Text
  observacoes   String?   @db.Text
  concluida     Boolean   @default(false)
  criado_em     DateTime  @default(now())
  atualizado_em DateTime  @updatedAt

  ambientes    medicao_orcamento_ambiente[]

  @@index([cliente_id])
  @@index([orcamento_id])
  @@map("medicao_orcamento")
}

// Pré-medição (rascunho): ambientes por cliente antes de existir agendamento técnico.
model pre_medicao {
  id             Int       @id @default(autoincrement())
  cliente_id     Int
  cliente        Cliente   @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  agenda_loja_id Int?
  agenda_loja    agenda_loja? @relation(fields: [agenda_loja_id], references: [id], onDelete: SetNull)
  status         String    @default("RASCUNHO") // RASCUNHO | STATUS_AGUARDANDO_VISITA | VINCULADA
  observacoes    String?   @db.Text
  criado_em      DateTime  @default(now())
  atualizado_em  DateTime  @updatedAt

  ambientes pre_medicao_ambiente[]

  @@index([cliente_id])
  @@index([agenda_loja_id])
  @@map("pre_medicao")
}

model pre_medicao_ambiente {
  id             Int       @id @default(autoincrement())
  pre_medicao_id Int
  pre_medicao    pre_medicao @relation(fields: [pre_medicao_id], references: [id], onDelete: Cascade)
  nome_ambiente  String    @db.VarChar(191)
  largura_m      Decimal?  @db.Decimal(10, 2)
  pe_direito_m   Decimal?  @db.Decimal(10, 2)
  profundidade_m Decimal?  @db.Decimal(10, 2)
  observacoes    String?   @db.Text
  medidas_json   String?   @db.Text
  criado_em      DateTime  @default(now())
  atualizado_em  DateTime  @updatedAt

  @@index([pre_medicao_id])
  @@unique([pre_medicao_id, nome_ambiente], map: "pre_medicao_ambiente_id_nome_unique")
  @@map("pre_medicao_ambiente")
}

// Ambientes medidos numa medição para orçamento (Cozinha, Suíte, etc.) — cada um com paredes (1:N)
model medicao_orcamento_ambiente {
  id                   Int      @id @default(autoincrement())
  medicao_orcamento_id Int
  medicao_orcamento   medicao_orcamento @relation(fields: [medicao_orcamento_id], references: [id], onDelete: Cascade)
  nome_ambiente       String   @db.VarChar(191)
  largura_m            Decimal? @db.Decimal(10, 2)
  pe_direito_m         Decimal? @db.Decimal(10, 2)
  profundidade_m       Decimal? @db.Decimal(10, 2)
  observacoes         String?  @db.Text
  medidas_json        String?  @db.Text
  criado_em            DateTime @default(now())
  atualizado_em        DateTime @updatedAt

  paredes              medicao_orcamento_parede[]

  @@unique([medicao_orcamento_id, nome_ambiente], map: "moa_orc_id_nome_ambiente_unique")
  @@index([medicao_orcamento_id])
  @@map("medicao_orcamento_ambiente")
}

// Paredes/Lados dentro de cada ambiente (ex: Cozinha > Parede Pia, Parede Geladeira) — medidas e fotos por parede
model medicao_orcamento_parede {
  id                            Int      @id @default(autoincrement())
  medicao_orcamento_ambiente_id Int
  medicao_orcamento_ambiente   medicao_orcamento_ambiente @relation(fields: [medicao_orcamento_ambiente_id], references: [id], onDelete: Cascade)
  nome                          String   @db.VarChar(191)
  largura_m                     Decimal? @db.Decimal(10, 2)
  pe_direito_m                  Decimal? @db.Decimal(10, 2)
  profundidade_m                Decimal? @db.Decimal(10, 2)
  observacoes                   String?  @db.Text
  medidas_json                  String?  @db.Text
  criado_em                     DateTime @default(now())
  atualizado_em                 DateTime @updatedAt

  @@unique([medicao_orcamento_ambiente_id, nome], name: "moa_parede_ambiente_id_nome_unique")
  @@index([medicao_orcamento_ambiente_id])
  @@map("medicao_orcamento_parede")
}

// Orçamento Técnico (novo fluxo): origem na medição por ambiente/parede; itens em tabela independente.
model orcamento_tecnico {
  id             Int      @id @default(autoincrement())
  agenda_loja_id Int
  agenda_loja    agenda_loja @relation(fields: [agenda_loja_id], references: [id], onDelete: Cascade)
  criado_em      DateTime @default(now())

  itens orcamento_tecnico_itens[]

  @@index([agenda_loja_id])
  @@map("orcamento_tecnico")
}

model orcamento_tecnico_itens {
  id              Int      @id @default(autoincrement())
  orcamento_tecnico_id Int
  orcamento_tecnico   orcamento_tecnico @relation(fields: [orcamento_tecnico_id], references: [id], onDelete: Cascade)
  nome_ambiente   String   @db.VarChar(191)
  descricao       String   @db.VarChar(500)
  valor_unitario  Decimal  @db.Decimal(10, 2)
  valor_total     Decimal  @db.Decimal(10, 2)
  observacao      String   @db.VarChar(2000)
  criado_em       DateTime @default(now())

  @@index([orcamento_tecnico_id])
  @@map("orcamento_tecnico_itens")
}

// ---------- Agenda Loja (setor LOJA) ----------
model agenda_loja {
  id Int @id @default(autoincrement())

  cliente_id Int?
  cliente    Cliente? @relation(fields: [cliente_id], references: [id])

  fornecedor_id Int?
  fornecedor    Fornecedor? @relation(fields: [fornecedor_id], references: [id])

  orcamento_id Int?
  orcamento    orcamentos? @relation(fields: [orcamento_id], references: [id])

  venda_id Int?
  venda    vendas? @relation(fields: [venda_id], references: [id])

  projeto_id Int?
  projeto    projetos? @relation(fields: [projeto_id], references: [id])

  titulo    String
  inicio_em DateTime
  fim_em    DateTime
  categoria String?
  origem_fluxo String?
  fluxo_tipo String?
  macroetapa String?
  subetapa String?
  execucao_etapa String?
  status    String   @default("PENDENTE")
  status_source String?
  status_aplicado_em DateTime?

  // Totem: custo coletivo (tempo total × custo hora médio fábrica) e tempo total para auditoria
  tempo_total_tarefa   Decimal? @db.Decimal(8, 2)
  custo_tarefa_fabrica Decimal? @db.Decimal(12, 2)

  equipe agenda_loja_funcionarios[]
  apontamentos agenda_loja_apontamentos[]
  apontamentos_producao apontamento_producao[]
  medicao_orcamento medicao_orcamento?
  pre_medicoes      pre_medicao[]
  orcamentos_tecnicos orcamento_tecnico[]

  criado_por_usuario_id Int?
  criado_por_usuario     usuarios? @relation("AgendaLojaCriadoPor", fields: [criado_por_usuario_id], references: [id], onDelete: SetNull)

  alterado_por_usuario_id Int?
  alterado_em              DateTime?
  alterado_por_usuario     usuarios? @relation("AgendaLojaAlteradoPor", fields: [alterado_por_usuario_id], references: [id], onDelete: SetNull)

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([cliente_id])
  @@index([fornecedor_id])
  @@index([orcamento_id])
  @@index([venda_id])
  @@index([inicio_em])
  @@index([categoria])
  @@index([origem_fluxo])
  @@index([fluxo_tipo])
  @@index([macroetapa])
  @@index([subetapa])
  @@index([execucao_etapa])
  @@index([status])
  @@index([status_source])
  @@index([criado_por_usuario_id])
  @@index([alterado_por_usuario_id])
  @@map("agenda_loja")
}

model agenda_loja_funcionarios {
  id             Int @id @default(autoincrement())
  agenda_loja_id Int
  funcionario_id Int

  agenda_loja agenda_loja @relation(fields: [agenda_loja_id], references: [id], onDelete: Cascade)
  funcionario funcionarios @relation(fields: [funcionario_id], references: [id], onDelete: Cascade)

  @@index([agenda_loja_id])
  @@index([funcionario_id])
  @@map("agenda_loja_funcionarios")
}

model agenda_loja_apontamentos {
  id             Int @id @default(autoincrement())
  agenda_loja_id Int
  funcionario_id Int
  inicio_em DateTime
  fim_em    DateTime
  criado_em DateTime @default(now())

  agenda_loja agenda_loja @relation(fields: [agenda_loja_id], references: [id], onDelete: Cascade)
  funcionario funcionarios @relation(fields: [funcionario_id], references: [id], onDelete: Cascade)

  @@index([agenda_loja_id])
  @@index([funcionario_id])
  @@map("agenda_loja_apontamentos")
}

// ---------- Agenda Fábrica (setor FABRICA/PRODUCAO) ----------
model agenda_fabrica {
  id Int @id @default(autoincrement())

  cliente_id Int?
  cliente    Cliente? @relation(fields: [cliente_id], references: [id])

  fornecedor_id Int?
  fornecedor    Fornecedor? @relation(fields: [fornecedor_id], references: [id])

  orcamento_id Int?        @unique
  orcamento    orcamentos? @relation(fields: [orcamento_id], references: [id])

  venda_id Int?
  venda    vendas? @relation(fields: [venda_id], references: [id])

  projeto_id Int?
  projeto    projetos? @relation(fields: [projeto_id], references: [id])

  plano_corte_id Int?         @unique
  plano_corte    plano_corte? @relation(fields: [plano_corte_id], references: [id])

  titulo    String
  inicio_em DateTime
  fim_em    DateTime
  categoria String?
  origem_fluxo String?
  fluxo_tipo String?
  macroetapa String?
  subetapa String?
  execucao_etapa String?
  status    String   @default("PENDENTE")
  status_source String?
  status_aplicado_em DateTime?

  // Ambientes desta tarefa (nomes). Vazio = todos da venda.
  ambientes_selecionados Json?

  // Totem: custo coletivo (tempo total × custo hora médio fábrica) e tempo total para auditoria
  tempo_total_tarefa   Decimal? @db.Decimal(8, 2)
  custo_tarefa_fabrica Decimal? @db.Decimal(12, 2)

  // Consumo e desvio (área peças Promob + perda padrão → consumo estimado; consumo real = peças + retalhos; perda real para DRE)
  area_pecas_m2      Decimal? @db.Decimal(12, 4)
  consumo_estimado_m2 Decimal? @db.Decimal(12, 4)
  consumo_real_m2    Decimal? @db.Decimal(12, 4)
  perda_real_m2     Decimal? @db.Decimal(12, 4)

  equipe agenda_fabrica_funcionarios[]
  apontamentos agenda_fabrica_apontamentos[]
  apontamentos_producao apontamento_producao[]
  retalhos estoque_retalho[]

  criado_por_usuario_id Int?
  criado_por_usuario     usuarios? @relation("AgendaFabricaCriadoPor", fields: [criado_por_usuario_id], references: [id], onDelete: SetNull)

  alterado_por_usuario_id Int?
  alterado_em              DateTime?
  alterado_por_usuario     usuarios? @relation("AgendaFabricaAlteradoPor", fields: [alterado_por_usuario_id], references: [id], onDelete: SetNull)

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([cliente_id])
  @@index([fornecedor_id])
  @@index([venda_id])
  @@index([plano_corte_id])
  @@index([inicio_em])
  @@index([categoria])
  @@index([origem_fluxo])
  @@index([fluxo_tipo])
  @@index([macroetapa])
  @@index([subetapa])
  @@index([execucao_etapa])
  @@index([status])
  @@index([status_source])
  @@index([criado_por_usuario_id])
  @@index([alterado_por_usuario_id])
  @@map("agenda_fabrica")
}

model estoque_retalho {
  id                Int      @id @default(autoincrement())
  produto_id        Int
  agenda_fabrica_id Int?
  largura_mm        Int
  comprimento_mm    Int
  quantidade_m2     Decimal  @db.Decimal(10, 4)
  status            String   @default("DISPONIVEL")
  reservado_para_tipo String?
  reservado_para_id Int?
  reservado_para_ref String?
  reservado_em      DateTime?
  imagem_url        String?  @db.VarChar(500)
  criado_em         DateTime @default(now())
  atualizado_em     DateTime @updatedAt

  produto        produtos        @relation(fields: [produto_id], references: [id], onDelete: Restrict)
  agenda_fabrica agenda_fabrica? @relation(fields: [agenda_fabrica_id], references: [id], onDelete: SetNull)

  @@index([produto_id])
  @@index([agenda_fabrica_id])
  @@index([status])
  @@index([reservado_para_tipo, reservado_para_id])
