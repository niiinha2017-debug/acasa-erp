# Copie para .env e preencha os valores.
# Produção (Ubuntu): use os mesmos nomes; DB_HOST=127.0.0.1 se MySQL for local.
# Veja também .env.production.example para variáveis opcionais.

NODE_ENV=development
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=acasa_user
DB_PASSWORD=SUA_SENHA
DB_DATABASE=acasa_erp

JWT_SECRET=UM_SEGREDO_FORTE_MINIMO_32_CHARS
PONTO_APP_URL=https://ponto.acasamarcenaria.com.br
PONTO_APK_URL=https://ponto.acasamarcenaria.com.br/acasa-ponto.apk

DATABASE_URL="mysql://acasa_user:SUA_SENHA@127.0.0.1:3306/acasa_erp"

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=SEU_EMAIL
MAIL_PASS=SUA_SENHA_APP
MAIL_FROM="ACASA ERP <SEU_EMAIL>"
MAIL_TEST_ENABLED=false

