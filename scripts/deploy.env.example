# Copie para deploy.env e preencha uma vez: cp deploy.env.example deploy.env
# Os scripts usam essas variáveis quando você faz: source scripts/deploy.env (ou . scripts/deploy.env)

# EC2 (SSH para publicar site, Tauri, etc.)
export KEY_PATH="/c/Users/Julyana Duarte/.ssh/acasa_key"
export EC2_HOST="ec2-user@54.164.55.32"
# Usuário do nginx no servidor: nginx (Amazon Linux) ou www-data (Ubuntu)
export REMOTE_WEB_USER="nginx"

# Ponto (subdomínio): servidor Ubuntu que atende ponto.acasamarcenaria.com.br
