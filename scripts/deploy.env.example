# export PONTO_REMOTE_WEB_USER="www-data"
# export PONTO_KEY_PATH="/caminho/para/chave/ubuntu"   # se for diferente de KEY_PATH

# Tauri (só para deploy do app desktop; senha da chave de assinatura)
export TAURI_SIGNING_PRIVATE_KEY_PASSWORD="acasa3358"
export TAURI_SIGNING_PRIVATE_KEY_PATH="/c/Users/Julyana Duarte/.ssh/tauri_private.key"

