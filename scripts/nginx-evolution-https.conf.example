# Expor Evolution API via HTTPS (sem precisar de subdomínio)
# Duas opções: por CAMINHO (no mesmo domínio) ou por SUBDOMÍNIO.

# ========== OPÇÃO 1: CAMINHO NO MESMO DOMÍNIO (não precisa criar subdomínio) ==========
# Adicione este bloco "location" DENTRO do server que já tem SSL para acasamarcenaria.com.br:
#
#   location /evolution-api/ {
#       proxy_pass http://127.0.0.1:8080/;
#       proxy_http_version 1.1;
#       proxy_set_header Upgrade $http_upgrade;
#       proxy_set_header Connection "upgrade";
#       proxy_set_header Host $host;
#       proxy_set_header X-Real-IP $remote_addr;
#       proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#       proxy_set_header X-Forwarded-Proto $scheme;
#       proxy_read_timeout 86400;
#   }
#
# No ERP (Configurações > Contato ou .env):
#   EVOLUTION_API_URL=https://acasamarcenaria.com.br/evolution-api
#   EVOLUTION_API_KEY=<sua-api-key>
#   EVOLUTION_INSTANCE_NAME=acasa-erp
#
# Depois: sudo nginx -t && sudo systemctl reload nginx

# ========== OPÇÃO 2: SUBDOMÍNIO (evolution.acasamarcenaria.com.br) ==========
# Só use se quiser um subdomínio. Exige registro DNS e certbot para o subdomínio.
#
# server {
#     listen 80;
#     server_name evolution.acasamarcenaria.com.br;
#     return 301 https://$server_name$request_uri;
# }
#
# server {
#     listen 443 ssl http2;
#     server_name evolution.acasamarcenaria.com.br;
#     ssl_certificate     /etc/letsencrypt/live/evolution.acasamarcenaria.com.br/fullchain.pem;
#     ssl_certificate_key /etc/letsencrypt/live/evolution.acasamarcenaria.com.br/privkey.pem;
#
#     location / {
#         proxy_pass http://127.0.0.1:8080;
#         proxy_http_version 1.1;
#         proxy_set_header Upgrade $http_upgrade;
#         proxy_set_header Connection "upgrade";
#         proxy_set_header Host $host;
#         proxy_set_header X-Real-IP $remote_addr;
#         proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#         proxy_set_header X-Forwarded-Proto $scheme;
#         proxy_read_timeout 86400;
#     }
# }
#
# EVOLUTION_API_URL=https://evolution.acasamarcenaria.com.br
