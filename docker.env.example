# Variáveis para o docker-compose (MySQL + Evolution API).
# Copie para .env na raiz do projeto:  cp docker.env.example .env
# Ou use:  docker-compose --env-file docker.env up -d
#
# Use a MESMA chave que está em backend/.env em EVOLUTION_API_KEY.

EVOLUTION_API_KEY=sua-api-key-aqui
EVOLUTION_SERVER_URL=http://localhost:8080
